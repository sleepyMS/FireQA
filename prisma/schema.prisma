generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── 인증 & 멀티테넌시 ───

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships OrganizationMembership[]
  activeUsers User[]   @relation("ActiveOrg")
  projects    Project[]
  uploads     Upload[]
  templates   QATemplate[]
  invitations Invitation[]
}

model User {
  id                   String   @id @default(cuid())
  supabaseId           String   @unique
  email                String   @unique
  name                 String?
  activeOrganizationId String?
  activeOrganization   Organization? @relation("ActiveOrg", fields: [activeOrganizationId], references: [id], onDelete: SetNull)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  memberships          OrganizationMembership[]
  apiTokens            ApiToken[]
  jobs                 GenerationJob[]
  projects             Project[]         @relation("CreatedBy")
  invitationsSent      Invitation[]      @relation("InvitedBy")
  invitationsAccepted  Invitation[]      @relation("AcceptedInvite")
  resultVersions       ResultVersion[]   @relation("ResultVersionCreator")
  diagramVersions      DiagramVersion[]  @relation("DiagramVersionCreator")

  @@index([supabaseId])
}

model OrganizationMembership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  joinedAt       DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String?
  role           String       @default("member") // "owner" | "admin" | "member"
  tokenHash      String       @unique
  status         String       @default("pending") // "pending" | "accepted" | "cancelled"
  expiresAt      DateTime
  invitedById    String
  invitedBy      User         @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedById   String?
  acceptedBy     User?        @relation("AcceptedInvite", fields: [acceptedById], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([tokenHash])
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String    @default("Figma Plugin") // 토큰 용도 식별
  tokenHash  String    @unique // SHA-256 해시로 저장
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([tokenHash])
}

model DeviceAuth {
  id         String   @id @default(cuid())
  deviceCode String   @unique
  userId     String?
  token      String?  // 승인 후 발급된 API 토큰 (평문, 1회 조회 후 삭제)
  status     String   @default("pending") // "pending" | "approved" | "expired"
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([deviceCode])
}

// ─── 비즈니스 모델 ───

model Project {
  id             String          @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String?
  createdBy      User?           @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  // 소프트 삭제 및 상태 관리: 물리적 삭제 대신 status 필드로 프로젝트 생명주기를 관리
  status         String          @default("active") // "active" | "archived" | "deleted"
  archivedAt     DateTime?
  deletedAt      DateTime?
  uploads        Upload[]
  jobs           GenerationJob[]

  @@index([organizationId, status]) // 조직별 활성/보관/삭제 프로젝트 필터링 성능 최적화
  @@index([deletedAt]) // 삭제된 프로젝트 조회 및 정리 작업 성능 최적화
}

model Upload {
  id             String          @id @default(cuid())
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fileName       String
  fileType       String
  fileSize       Int
  storagePath    String
  parsedText     String?
  createdAt      DateTime        @default(now())
  jobs           GenerationJob[]

  @@index([organizationId])
}

model GenerationJob {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadId   String
  upload     Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type       String   // "test-cases" | "diagrams" | "wireframes"
  status     String   @default("pending") // "pending" | "processing" | "completed" | "failed"
  config     String   @default("{}") // JSON
  result     String?  // JSON
  error      String?
  tokenUsage Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resultVersions  ResultVersion[]
  diagramVersions DiagramVersion[]

  @@index([userId])
}

model DiagramVersion {
  id             String        @id @default(cuid())
  jobId          String
  job            GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade) // 정식 FK 추가 (기존 jobId 컬럼에 제약 조건 연결)
  diagramTitle   String
  mermaidCode    String
  nodesJson      String        @default("[]") // JSON: nodes 배열
  edgesJson      String        @default("[]") // JSON: edges 배열
  instruction    String?       // 이 버전을 만든 요구사항 (null이면 초기 생성)
  version        Int           // 1, 2, 3...
  isConfirmed    Boolean       @default(false) // 확정 여부
  createdById    String?       // 버전을 생성한 사용자 (null이면 시스템 생성)
  createdBy      User?         @relation("DiagramVersionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())

  @@index([jobId, diagramTitle])
}

model ResultVersion {
  id            String        @id @default(cuid())
  jobId         String
  job           GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  version       Int
  resultJson    String        // GenerationJob.result 전체 스냅샷
  changeType    String        // "initial" | "ai-improve" | "ai-fix" | "manual-edit" | "revert"
  changeSummary String?
  instruction   String?
  isActive      Boolean       @default(false)
  createdById   String?
  createdBy     User?         @relation("ResultVersionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())

  @@unique([jobId, version])
  @@index([jobId, isActive])
}

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String?
  action         String   // "{domain}.{verb}" e.g. "generation.completed"
  projectId      String?
  jobId          String?  // plain string, no FK — log survives job deletion
  metadata       String   @default("{}") // JSON
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
}

model Comment {
  id             String    @id @default(cuid())
  organizationId String
  authorId       String
  jobId          String?
  targetItemId   String?   // TC ID, diagram title, screen ID, etc. (logical ref, no FK)
  parentId       String?
  parent         Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies        Comment[] @relation("CommentThread")
  body           String
  isResolved     Boolean   @default(false)
  resolvedById   String?
  resolvedAt     DateTime?
  editedAt       DateTime?
  deletedAt      DateTime? // 소프트 삭제
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([jobId, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([parentId])
}

model QATemplate {
  id             String       @id @default(cuid())
  name           String
  description    String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sheetConfig    String       @default("[]") // JSON
  columnConfig   String       @default("{}") // JSON
  constraints    String       @default("") // 제약조건 (최우선 준수)
  requirements   String       @default("") // 요구사항 (희망 사항)
  isDefault      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}
