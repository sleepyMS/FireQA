generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  uploads     Upload[]
  jobs        GenerationJob[]
}

model Upload {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileName    String
  fileType    String
  fileSize    Int
  storagePath String
  parsedText  String?
  createdAt   DateTime        @default(now())
  jobs        GenerationJob[]
}

model GenerationJob {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadId   String
  upload     Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  type       String   // "test-cases" | "diagrams" | "wireframes"
  status     String   @default("pending") // "pending" | "processing" | "completed" | "failed"
  config     String   @default("{}") // JSON
  result     String?  // JSON
  error      String?
  tokenUsage Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DiagramVersion {
  id             String   @id @default(cuid())
  jobId          String
  diagramTitle   String
  mermaidCode    String
  nodesJson      String   @default("[]") // JSON: nodes 배열
  edgesJson      String   @default("[]") // JSON: edges 배열
  instruction    String?  // 이 버전을 만든 요구사항 (null이면 초기 생성)
  version        Int      // 1, 2, 3...
  isConfirmed    Boolean  @default(false) // 확정 여부
  createdAt      DateTime @default(now())

  @@index([jobId, diagramTitle])
}

model QATemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  sheetConfig  String   @default("[]") // JSON
  columnConfig String   @default("{}") // JSON
  constraints  String   @default("") // 제약조건 (최우선 준수)
  requirements String   @default("") // 요구사항 (희망 사항)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
